generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CLIENT
  VENDOR
  USER
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum CompanyType {
  CLIENT
  VENDOR
}

enum RequirementStatus {
  UPLOADED
  PROCESSING
  CLIENT_REVIEW
  FINALIZED
  REJECTED
}

enum AuditStatus {
  INVITED
  ACCEPTED
  REJECTED
  SCHEDULED
  COMPLETED
}

enum AuctionStatus {
  DRAFT
  UPCOMING
  SEALED_PHASE
  OPEN_PHASE
  PENDING_SELECTION
  COMPLETED
  CANCELLED
}

enum BidPhase {
  SEALED
  OPEN
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum PickupStatus {
  PENDING
  GATE_PASS_ISSUED
  VENDOR_ACKNOWLEDGED
  IN_TRANSIT
  SCHEDULED
  DOCUMENTS_UPLOADED
  RECONCILIATION_DONE
  INVOICE_GENERATED
  COMPLETED
}

