model UserProduct {
  id              String             @id @default(cuid())
  userId          String
  name            String
  weightKg        Float
  condition       String
  askingPrice     Float
  description     String?
  photoS3Keys     String[]           @default([])
  photoS3Bucket   String?
  invoiceS3Key    String?
  invoiceS3Bucket String?
  invoiceFileName String?
  status          UserProductStatus  @default(PENDING_ADMIN_REVIEW)
  adminApprovedAt DateTime?
  adminRemarks    String?
  acceptedQuoteId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickup          UserProductPickup?
  quotes          UserProductQuote[]
}

model UserProductQuote {
  id              String      @id @default(cuid())
  productId       String
  vendorCompanyId String
  offeredPrice    Float
  remarks         String?
  status          String      @default("pending")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  product         UserProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendorCompany   Company     @relation(fields: [vendorCompanyId], references: [id])
}

model UserProductPickup {
  id              String      @id @default(cuid())
  productId       String      @unique
  vendorCompanyId String
  status          String      @default("requested")
  scheduledDate   DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  product         UserProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendorCompany   Company     @relation(fields: [vendorCompanyId], references: [id])
}

enum UserProductStatus {
  PENDING_ADMIN_REVIEW
  ADMIN_APPROVED
  QUOTE_RECEIVED
  QUOTE_ACCEPTED
  PICKUP_REQUESTED
  PICKUP_IN_PROGRESS
  COMPLETED
  REJECTED
}
