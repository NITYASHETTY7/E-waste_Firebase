model Payment {
  id               String        @id @default(cuid())
  status           PaymentStatus @default(PENDING)
  clientAmount     Float
  commissionAmount Float
  totalAmount      Float
  utrNumber        String?
  proofS3Key       String?
  proofS3Bucket    String?
  auctionId        String        @unique
  adminNotes       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  paymentProofUrl  String?
  auction          Auction       @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  pickup           Pickup?
}

model Pickup {
  id                   String           @id @default(cuid())
  status               PickupStatus     @default(PENDING)
  scheduledDate        DateTime?
  auctionId            String           @unique
  paymentId            String?          @unique
  adminNotes           String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  finalWeight          Float?
  gatePassNumber       String?
  gatePassIssuedAt     DateTime?
  vehicleNumber        String?
  driverName           String?
  pickupNotes          String?
  vendorAcknowledgedAt DateTime?
  reconciliationNotes  String?
  finalAmount          Float?
  invoiceNumber        String?
  invoiceGeneratedAt   DateTime?
  invoiceS3Key         String?
  gatePassDocS3Key     String?
  gatePassDocBucket    String?
  gatePassDocFileName  String?
  vendorVehicleNumber  String?
  vendorDriverName     String?
  vendorPreferredDate  DateTime?
  clientVerifiedAt     DateTime?
  auction              Auction          @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  payment              Payment?         @relation(fields: [paymentId], references: [id])
  pickupDocs           PickupDocument[]
}

model PickupDocument {
  id         String       @id @default(cuid())
  type       DocumentType
  s3Key      String
  s3Bucket   String
  fileName   String
  mimeType   String?
  pickupId   String
  uploadedAt DateTime     @default(now())
  pickup     Pickup       @relation(fields: [pickupId], references: [id], onDelete: Cascade)
}

model Rating {
  id            String   @id @default(cuid())
  auctionId     String
  fromCompanyId String
  toCompanyId   String
  score         Int
  comment       String?
  type          String
  createdAt     DateTime @default(now())
  auction       Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  fromCompany   Company  @relation("RatingsGiven", fields: [fromCompanyId], references: [id])
  toCompany     Company  @relation("RatingsReceived", fields: [toCompanyId], references: [id])

  @@unique([auctionId, fromCompanyId, type])
}
