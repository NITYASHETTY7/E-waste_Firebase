// ─── Users & Companies ────────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  name          String
  phone         String?
  role          UserRole      @default(USER)
  companyId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  emailVerified Boolean       @default(false)
  isActive      Boolean       @default(false)
  otpAttempts   Int           @default(0)
  otpCode       String?
  otpExpiresAt  DateTime?
  otpType       String?
  phoneVerified Boolean       @default(false)
  // USER-role profile fields
  dob               String?
  address           String?
  panNumber         String?
  bankAccountHolder String?
  bankName          String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankAccountType   String?

  auditReports       AuditReport[]
  bids               Bid[]
  auditDocs          VendorAuditDoc[]   @relation("VendorAuditDocs")
  inAppNotifications InAppNotification[]
  company            Company?           @relation(fields: [companyId], references: [id])
  userProducts       UserProduct[]

  @@index([email])
}

model Company {
  id                String        @id @default(cuid())
  name              String
  type              CompanyType
  status            CompanyStatus @default(PENDING)
  gstNumber         String?
  panNumber         String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  rating            Float?        @default(0)
  ratingCount       Int           @default(0)
  bankAccountHolder String?
  bankName          String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankAccountType   String?
  isLocked          Boolean       @default(false)
  lockReason        String?
  penaltyAmount     Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  auctions         Auction[]         @relation("ClientAuctions")
  wonAuctions      Auction[]         @relation("WinnerAuctions")
  auditInvitations AuditInvitation[] @relation("VendorAuditInvitations")
  kycDocuments     KycDocument[]
  requirements     Requirement[]     @relation("ClientRequirements")
  users            User[]
  ratingsGiven        Rating[]             @relation("RatingsGiven")
  ratingsReceived     Rating[]             @relation("RatingsReceived")
  userProductQuotes   UserProductQuote[]
  userProductPickups  UserProductPickup[]
}

model KycDocument {
  id         String       @id @default(cuid())
  type       DocumentType
  s3Key      String       @unique
  s3Bucket   String
  fileName   String
  mimeType   String?
  companyId  String
  uploadedAt DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id])
}
